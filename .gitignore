# profile - .gitignore
#
# MASH stack (Rust + Bun-built Tailwind). Organised by area.

# -----------------------------------------------------------------------------
# Rust / Cargo
# -----------------------------------------------------------------------------
target/
**/target/
*.rs.bk
perf.data
perf.data.old
flamegraph.svg
# Cargo.lock is COMMITTED (this ships a binary, not a library).

# -----------------------------------------------------------------------------
# Node / Bun (Tailwind CLI - build-time only, not in the runtime image)
# -----------------------------------------------------------------------------
node_modules/
**/node_modules/
.bun/
# bun.lock (text) is COMMITTED.

# -----------------------------------------------------------------------------
# Environment / secrets
# -----------------------------------------------------------------------------
.env
.env.*
*.pem
*.key

# -----------------------------------------------------------------------------
# Editors / IDEs
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Project-specific
# -----------------------------------------------------------------------------
cv/             # CV source files
drafts/         # unpublished article drafts
*.log

# ROML - separate project (documentation compiler spec).
/ROML/
